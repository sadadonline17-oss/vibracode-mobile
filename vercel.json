{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @workspace/vibracode-mobile run build:web",
  "outputDirectory": "artifacts/vibracode-mobile/dist",
  "framework": null,
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/api/terminal/(.*)", "destination": "/api/terminal.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

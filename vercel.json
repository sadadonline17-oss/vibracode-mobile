{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @workspace/vibracode-mobile run build:web",
  "outputDirectory": "artifacts/vibracode-mobile/dist",
  "framework": null,
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

{
  "cli": {
    "version": ">= 18.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_PUBLIC_CONVEX_URL": "https://judicious-robin-234.convex.cloud",
        "EXPO_PUBLIC_BACKEND_URL": "https://vibracode-mobile.vercel.app/api"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_CONVEX_URL": "https://judicious-robin-234.convex.cloud",
        "EXPO_PUBLIC_BACKEND_URL": "https://vibracode-mobile.vercel.app/api"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CONVEX_URL": "https://judicious-robin-234.convex.cloud"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
